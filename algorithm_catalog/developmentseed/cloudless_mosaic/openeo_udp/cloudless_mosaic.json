      },
      "default": 30,
      "optional": true
    },
    {
      "name": "brighten_scale",
      "description": "Brightening multiplier applied to valid/invalid reflectance values before merging (mirrors the constant 5 used in the original evalscript for visual brightness)",
      "schema": {
