{
  "process_graph": {
    "loadcollection1": {
      "process_id": "load_collection",
      "arguments": {
        "bands": [
          "B02",
          "B04",
          "B08",
          "B11"
        ],
        "id": "SENTINEL2_L2A",
        "properties": {
          "eo:cloud_cover": {
            "process_graph": {
              "lte1": {
                "process_id": "lte",
                "arguments": {
                  "x": {
                    "from_parameter": "value"
                  },
                  "y": 30
                },
                "result": true
              }
            }
          }
        },
        "spatial_extent": {
          "from_parameter": "bounding_box"
        },
        "temporal_extent": {
          "from_parameter": "time"
        }
      }
    },
    "reducedimension1": {
      "process_id": "reduce_dimension",
      "arguments": {
        "data": {
          "from_node": "loadcollection1"
        },
        "dimension": "t",
        "reducer": {
          "process_graph": {
            "first1": {
              "process_id": "first",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                }
              },
              "result": true
            }
          }
        }
      }
    },
    "applydimension1": {
      "process_id": "apply_dimension",
      "arguments": {
        "data": {
          "from_node": "reducedimension1"
        },
        "dimension": "bands",
        "process": {
          "process_graph": {
            "arrayelement1": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 3
              }
            },
            "divide1": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement1"
                },
                "y": 10000.0
              }
            },
            "arrayelement2": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 1
              }
            },
            "divide2": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement2"
                },
                "y": 10000.0
              }
            },
            "add1": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide1"
                },
                "y": {
                  "from_node": "divide2"
                }
              }
            },
            "arrayelement3": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 2
              }
            },
            "divide3": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement3"
                },
                "y": 10000.0
              }
            },
            "arrayelement4": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 0
              }
            },
            "divide4": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement4"
                },
                "y": 10000.0
              }
            },
            "add2": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": {
                  "from_node": "divide4"
                }
              }
            },
            "subtract1": {
              "process_id": "subtract",
              "arguments": {
                "x": {
                  "from_node": "add1"
                },
                "y": {
                  "from_node": "add2"
                }
              }
            },
            "add3": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide1"
                },
                "y": {
                  "from_node": "divide2"
                }
              }
            },
            "add4": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": {
                  "from_node": "divide4"
                }
              }
            },
            "add5": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "add3"
                },
                "y": {
                  "from_node": "add4"
                }
              }
            },
            "divide5": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "subtract1"
                },
                "y": {
                  "from_node": "add5"
                }
              }
            },
            "multiply1": {
              "process_id": "multiply",
              "arguments": {
                "x": 2.5,
                "y": {
                  "from_node": "divide5"
                }
              }
            },
            "arraycreate1": {
              "process_id": "array_create",
              "arguments": {
                "data": [
                  {
                    "from_node": "multiply1"
                  },
                  {
                    "from_node": "divide3"
                  },
                  {
                    "from_node": "divide1"
                  }
                ]
              },
              "result": true
            }
          }
        }
      }
    },
    "saveresult1": {
      "process_id": "save_result",
      "arguments": {
        "data": {
          "from_node": "applydimension1"
        },
        "format": "GTiff",
        "options": {}
      },
      "result": true
    }
  },
  "parameters": [
    {
      "name": "time",
      "description": "Temporal range for data acquisition",
      "schema": {
        "type": "array",
        "subtype": "temporal-interval"
      },
      "default": [
        "2019-04-15",
        "2019-04-20"
      ],
      "optional": true
    },
    {
      "name": "bounding_box",
      "description": "Spatial extent for South of Ljubljana, Slovenia",
      "schema": {
        "type": "object",
        "subtype": "bounding-box"
      },
      "default": {
        "west": 14.44,
        "south": 45.95,
        "east": 14.58,
        "north": 46.01
      },
      "optional": true
    },
    {
      "name": "cloud_cover",
      "description": "Maximum scene-level cloud cover percentage",
      "schema": {
        "type": "number"
      },
      "default": 30,
      "optional": true
    },
    {
      "name": "brightness",
      "description": "Gain applied to the BSI channel of the RGB composite",
      "schema": {
        "type": "number"
      },
      "default": 2.5,
      "optional": true
    }
  ],
  "id": "barren_soil",
  "summary": "Barren Soil Index (BSI) visualization from Sentinel-2 imagery using openEO.",
  "description": "Visualizes barren and bare soil from Sentinel-2 L2A imagery using the Barren Soil Index (Nguyen et al., 2021), computed from SWIR, red, NIR and blue reflectance. The result is rendered as an RGB composite with BSI on the red channel, NIR on green and SWIR on blue, so vegetation renders green and barren ground renders red. Converted from the Sentinel Hub Barren Soil evalscript."
}